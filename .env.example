# Server Configuration
SERVER_PORT=8080

# Relational Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=bankmind
DB_USER=bankmind_user
DB_PASSWORD=bankmind_pass
DB_ROOT_PASSWORD=rootpassword

# Vector Database Configuration (Qdrant)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# Security & JWT Configuration
# Generate a secure HS256 base64-encoded secret key or a 256-bit plain-text string
JWT_SECRET=YOUR_SUPER_SECRET_KEY_JWT_MUST_BE_AT_LEAST_256_BITS_FOR_HS256
JWT_EXPIRATION_MS=3600000
JWT_REFRESH_EXPIRATION_MS=86400000

# LLM / LangChain4j API Keys
OPENAI_API_KEY=your-openai-api-key-here
EMBEDDING_MODEL_NAME=text-embedding-3-small-v1
CHAT_MODEL_NAME=gpt-4o
